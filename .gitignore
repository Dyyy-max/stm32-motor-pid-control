*.uvguix
*.uvguix.*
*.uvopt
*.uvoptx
*.uvoptx.bak

# Build directories
Objects/
Listings/
DebugConfig/
RTE/

# Keil backup files
*.bak
*~

# ==================== STM32CubeMX 生成的文件 ====================
.mxproject

